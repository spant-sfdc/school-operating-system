// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Sprint 0 — Data Foundation. Only Migration 000 (Audit Foundation) and
// Migration 001 (School Foundation) are implemented here — see
// docs/database/MIGRATION_PLAN.md § 2 for the full sequence and
// docs/database/PRISMA_IMPLEMENTATION_GUIDE.md for the conventions this
// file follows (naming, relation mode, datasource split).
//
// Once this schema exceeds ~15 models (PRISMA_IMPLEMENTATION_GUIDE.md § 1),
// split into prisma/schema/ by bounded context. Two models doesn't warrant
// that yet.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URLs are no longer configured here in Prisma 7 — `url`/`directUrl`
// on the datasource block were removed. Migrations read the connection from
// prisma.config.ts (DIRECT_URL, unpooled); the runtime client connects via a
// driver adapter (@prisma/adapter-pg, DATABASE_URL, pooled) constructed in
// src/lib/db.ts. See docs/database/PRISMA_IMPLEMENTATION_GUIDE.md § 2.
datasource db {
  provider = "postgresql"
}

// --- Migration 000: Audit Foundation ---------------------------------------
// Structurally standalone, no FKs out — see docs/database/MIGRATION_PLAN.md § 1
// for why AuditLog is built first, not last. Uses a time-ordered ID (UUIDv7)
// per docs/database/DATABASE_REVIEW.md § 11 — high insert volume, B-tree
// locality matters. Append-only: no updatedAt, no deletedAt (see
// docs/domain/DOMAIN_MODEL.md § 9.1). The REVOKE UPDATE/DELETE grant
// enforcement from docs/database/AUDIT_STRATEGY.md § 2 requires a real
// Postgres role name this environment doesn't have yet — see this sprint's
// "Manual Actions Required" note, not applied in this migration.
// Partitioning (AUDIT_STRATEGY.md § 3) deliberately deferred: created
// unpartitioned, with no composite primary key or unique constraint that
// would block converting it to a partitioned table later.

enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE

  @@map("audit_action")
}

model AuditLog {
  id          String      @id @default(uuid(7))
  schoolId    String      @map("school_id")
  entityType  String      @map("entity_type")
  entityId    String      @map("entity_id")
  actorUserId String      @map("actor_user_id")
  action      AuditAction
  beforeValue Json?       @map("before_value")
  afterValue  Json?       @map("after_value")
  timestamp   DateTime    @default(now()) @db.Timestamptz(3)

  @@index([entityType, entityId])
  @@index([actorUserId, timestamp])
  @@index([schoolId, timestamp])
  @@map("audit_logs")
}

// --- Migration 001: School Foundation ---------------------------------------
// The schoolId root every later migration hangs off — see
// docs/database/MIGRATION_PLAN.md § 2. School.schoolId is the primary key
// field name itself (not a generic `id`), since every other table's FK to
// School is named schoolId — see docs/domain/DATABASE_SCHEMA.md § 3.
// SchoolStatus's exact values aren't specified in docs/domain/DOMAIN_MODEL.md
// or docs/domain/DATABASE_SCHEMA.md (only AcademicYearStatus's ACTIVE|CLOSED
// is spelled out there) — ACTIVE/INACTIVE chosen here as the minimal
// two-state default consistent with this system's current single-tenant
// scope; INACTIVE has no application behavior yet.

enum SchoolStatus {
  ACTIVE
  INACTIVE

  @@map("school_status")
}

enum AcademicYearStatus {
  ACTIVE
  CLOSED

  @@map("academic_year_status")
}

model School {
  schoolId         String       @id @default(cuid()) @map("school_id")
  name             String
  shortName        String?      @map("short_name")
  affiliationBoard String?      @map("affiliation_board")
  udiseCode        String?      @unique @map("udise_code")
  status           SchoolStatus @default(ACTIVE)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  academicYears      AcademicYear[]
  users              User[]
  schoolClasses      SchoolClass[]
  students           Student[]
  guardians          Guardian[]
  enrollments        Enrollment[]
  subjects           Subject[]
  teachers           Teacher[]
  attendanceSessions AttendanceSession[]

  @@map("schools")
}

model AcademicYear {
  id              String             @id @default(cuid())
  schoolId        String             @map("school_id")
  school          School             @relation(fields: [schoolId], references: [schoolId])
  label           String
  startDate       DateTime           @map("start_date") @db.Timestamptz(3)
  endDate         DateTime           @map("end_date") @db.Timestamptz(3)
  isCurrent       Boolean            @default(false) @map("is_current")
  // Exactly one true per school — schema-enforced via a partial unique index
  // (WHERE is_current = true), hand-added in this migration's SQL, not
  // expressible in schema.prisma syntax. See
  // docs/database/CONSTRAINT_STRATEGY.md § 3.
  status          AcademicYearStatus @default(ACTIVE)
  promotionPolicy Json               @map("promotion_policy")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  sections           Section[]
  enrollments        Enrollment[]
  teacherAssignments TeacherAssignment[]

  @@unique([schoolId, label])
  @@index([schoolId, isCurrent])
  @@map("academic_years")
}

// --- Migration 002: Identity Foundation -------------------------------------
// Sprint 1. Physically the second migration built after 001 — numbered 002
// since Migration 002 (Academic Structure — Class/Section/Subject) in
// docs/database/MIGRATION_PLAN.md § 2 hasn't been built yet. Valid ordering:
// that table's own "Depends on" column lists Identity as depending only on
// 001, not on Academic Structure. See MIGRATION_PLAN.md's Sprint 1 status
// note for the full reconciliation — this is a build-order note, not a
// redesign of the conceptual plan.
//
// Scope is narrower than MIGRATION_PLAN.md's original "Migration 003 —
// Identity" slot: `Teacher`/`TeacherQualification` are explicitly out of
// this sprint ("no business modules") and remain for a later migration.
// `Role`, `Account`, `Session`, `VerificationToken` are new — the Auth.js
// adapter's own required shape, which the conceptual domain model never
// modeled (auth infrastructure, not a business entity). See
// docs/DECISIONS.md's Sprint 1 entry.
//
// `Account`/`Session` follow Auth.js v5's (@auth/prisma-adapter) canonical
// Prisma schema exactly — including keeping `Account`'s OAuth-response
// fields (access_token, refresh_token, expires_at, token_type, id_token,
// session_state) as literal snake_case field names, not this project's
// usual camelCase-field-with-@map convention. The adapter constructs its
// Prisma calls using these exact literal keys; renaming them would silently
// break OAuth token storage. This is a deliberate, narrow exception to
// DEVELOPMENT_CONVENTIONS.md § 1, not an oversight.

enum AccessLevel {
  ADMIN
  TEACHER

  @@map("access_level")
}

// A lookup/reference table, not a many-to-many join — every User has
// exactly one Role in V1 (D-001: Guest/Admin/Teacher only). `name` is the
// human-facing job title ("Administrator", "Principal", "Teacher");
// `accessLevel` is the actual permission tier PERMISSION_MATRIX.md's rules
// check against. Two different `name` rows can share one `accessLevel` —
// PROJECT_CONTEXT.md § 4 already describes "Admin" as covering "Principal /
// Management / School Office" job titles, so seeding "Administrator" and
// "Principal" as two Role rows, both ADMIN-tier, matches that framing
// exactly rather than introducing a fourth real permission tier.
model Role {
  id          String      @id @default(cuid())
  name        String      @unique
  accessLevel AccessLevel @map("access_level")
  description String?
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  users User[]

  @@map("roles")
}

// Auth.js adapter User, extended with this app's own fields (schoolId,
// roleId, passwordHash, deactivatedAt) — one User table serves both
// purposes, per ARCHITECTURE.md § 9's Auth.js provider question ("wire in
// whichever provider is chosen") remaining unresolved by design: this
// schema supports either a Credentials or an email/magic-link provider
// without redesign. `roleId` is required, not nullable — this app has no
// public self-registration (D-001; Admin provisions every account), so
// every real User row is created through an Admin-driven flow that assigns
// a role at creation time, never through the adapter's own auto-create path.
model User {
  id            String    @id @default(cuid())
  schoolId      String    @map("school_id")
  school        School    @relation(fields: [schoolId], references: [schoolId])
  roleId        String    @map("role_id")
  role          Role      @relation(fields: [roleId], references: [id])
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified") @db.Timestamptz(3)
  image         String?
  passwordHash  String?   @map("password_hash")
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  accounts Account[]
  sessions Session[]
  teacher  Teacher?

  @@index([schoolId])
  @@index([roleId])
  @@map("users")
}

// Auth.js adapter Account — OAuth provider link. Field names/shapes are the
// adapter's own contract, see the migration-header comment above.
model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// Auth.js adapter Session — database session strategy.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Auth.js adapter VerificationToken — email/magic-link + email-verification
// flows. No single `id` field, per the adapter's own canonical schema — the
// composite (identifier, token) unique constraint is this model's key.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz(3)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Migration 003: Academic Foundation -------------------------------------
// Sprint 2. Physically the third migration, and — unlike Sprint 1's Migration
// 002 — its content now genuinely matches docs/database/MIGRATION_PLAN.md's
// original "Migration 002 — Academic structure" row (Class/Section/Subject),
// just built one physical slot later since Identity took "002". `ClassSubject`
// (the many-to-many linking subjects to classes) is deliberately NOT built
// here — out of this sprint's explicit scope; subjects and classes remain
// unlinked until a future migration. See MIGRATION_PLAN.md's Sprint 2 status
// note and docs/DECISIONS.md's Sprint 2 entry.
//
// Named `SchoolClass`, not `Class` — this task's own explicit naming
// instruction, and a real technical reason independent of that instruction:
// `class` is a reserved word in JavaScript/TypeScript, and Prisma-generated
// client code and query-builder chains read awkwardly (and in some contexts
// are outright invalid identifiers) for a model literally named `Class`.
// Every field/relation name follows suit (`schoolClassId`, not `classId`).
//
// All three models carry `deletedAt` (soft-deletable) and a uniqueness rule
// scoped `WHERE deleted_at IS NULL` — a partial unique index, hand-added in
// this migration's SQL, not expressible in schema.prisma syntax (same
// pattern as Migration 001's AcademicYear.isCurrent). The plain @@index
// below supports that hand-added constraint; it is not the constraint
// itself. Per docs/database/SOFT_DELETE_STRATEGY.md § 2 and
// docs/database/INDEXING_STRATEGY.md § 1 (`Class: @@unique([schoolId,
// name])`, `Section: @@unique([classId, academicYearId, name])`, `Subject:
// @@unique([schoolId, name])`) — applied here even though
// docs/domain/DATABASE_SCHEMA.md § 3's illustrative `Class` block doesn't
// show the constraint inline; INDEXING_STRATEGY.md's consolidated table is
// the authoritative reference per its own stated purpose.

model SchoolClass {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  school    School    @relation(fields: [schoolId], references: [schoolId])
  name      String
  sortOrder Int       @map("sort_order")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  sections Section[]

  @@index([schoolId, name])
  @@map("school_classes")
}

model Section {
  id             String       @id @default(cuid())
  academicYearId String       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  schoolClassId  String       @map("school_class_id")
  schoolClass    SchoolClass  @relation(fields: [schoolClassId], references: [id])
  name           String
  capacity       Int?
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(3)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  enrollments        Enrollment[]
  teacherAssignments TeacherAssignment[]
  attendanceSessions AttendanceSession[]

  @@index([schoolClassId, academicYearId, name])
  @@map("sections")
}

model Subject {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  school    School    @relation(fields: [schoolId], references: [schoolId])
  name      String
  code      String?
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  teacherAssignments TeacherAssignment[]

  @@index([schoolId, name])
  @@map("subjects")
}

// --- Migration 004: Student Foundation --------------------------------------
// Sprint 3. Student, Guardian, StudentGuardian, Enrollment — see
// docs/database/MIGRATION_PLAN.md's Sprint 3 status note and
// docs/DECISIONS.md's Sprint 3 entry.
//
// `Student.admissionNumber` is `@@unique([schoolId, admissionNumber])`, not
// globally unique — docs/domain/DATABASE_SCHEMA.md § 4's illustrative block
// shows it as a bare `@unique`, but docs/database/DATABASE_REVIEW.md § 2
// explicitly flags this as wrong ("two schools will independently issue
// STU-001"), the same class of gap D-025/D-026 already fixed for
// TransferCertificate.tcNumber. `udisePen` stays genuinely globally unique
// (a real national identifier, correctly cross-school).
//
// Per docs/database/DATABASE_REVIEW.md § 2, `Student` has NO `deletedAt` —
// `status` is the only lifecycle signal; a second delete mechanism would
// create two competing "is this student gone" answers.
//
// `Enrollment.id` uses a time-ordered ID (UUIDv7), per
// docs/database/DATABASE_REVIEW.md § 8/§ 11 — it's the FK target every
// future high-volume child table (AttendanceRecord, MarksRecord) will
// reference, so insertion-ordered IDs here improve those tables' own index
// locality, consistent with this project's existing ULID/UUIDv7 adoption
// for AuditLog. `Enrollment` itself has no delete mechanism of any kind —
// it IS the append-only history record.
//
// `StudentGuardian.relationshipType` promoted to a native enum per
// docs/database/ENUM_STRATEGY.md § 2 (already listed there as a
// recommended-enum field, "fixed small enum, not school-configurable").

enum StudentStatus {
  ACTIVE
  ALUMNI
  TRANSFERRED_OUT
  WITHDRAWN

  @@map("student_status")
}

enum RelationshipType {
  FATHER
  MOTHER
  LEGAL_GUARDIAN
  OTHER

  @@map("relationship_type")
}

model Student {
  id              String        @id @default(cuid())
  schoolId        String        @map("school_id")
  school          School        @relation(fields: [schoolId], references: [schoolId])
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  dateOfBirth     DateTime      @map("date_of_birth") @db.Timestamptz(3)
  gender          String?
  photoUrl        String?       @map("photo_url")
  udisePen        String?       @unique @map("udise_pen")
  admissionNumber String        @map("admission_number")
  category        String?
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  studentGuardians StudentGuardian[]
  enrollments      Enrollment[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, status])
  @@map("students")
}

model Guardian {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  school    School    @relation(fields: [schoolId], references: [schoolId])
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  phone     String
  email     String?
  address   String?
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  studentGuardians StudentGuardian[]

  // No uniqueness on phone, deliberately — docs/database/DATABASE_REVIEW.md
  // § 3: two different guardian records can legitimately share a phone
  // number. Indexed anyway — "a parent calls, staff looks them up by
  // phone" is this table's single most important query pattern.
  @@index([phone])
  @@map("guardians")
}

// Join table. `(studentId, guardianId)` uniqueness is scoped
// WHERE deleted_at IS NULL — a hand-added partial unique index, same
// pattern as Migration 003's soft-deletable tables, per
// docs/database/SOFT_DELETE_STRATEGY.md § 2. The plain @@index below
// supports that hand-added constraint; it is not the constraint itself.
model StudentGuardian {
  id                    String           @id @default(cuid())
  studentId             String           @map("student_id")
  student               Student          @relation(fields: [studentId], references: [id])
  guardianId            String           @map("guardian_id")
  guardian              Guardian         @relation(fields: [guardianId], references: [id])
  relationshipType      RelationshipType @map("relationship_type")
  isPrimaryContact      Boolean          @default(false) @map("is_primary_contact")
  isAuthorizedForPickup Boolean          @default(false) @map("is_authorized_for_pickup")
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz(3)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([studentId, guardianId])
  // "All children of this guardian" per docs/database/DATABASE_REVIEW.md
  // § 3 — the unique's leading column is studentId, so this needs its own
  // index rather than relying on the composite above.
  @@index([guardianId])
  @@map("student_guardians")
}

// The aggregate root for all academic history — see
// docs/database/DATABASE_REVIEW.md § 1's "Identity vs. Fact" principle and
// § 8. No delete mechanism of any kind, not even deletedAt: a promotion or
// withdrawal creates a new Enrollment or sets status elsewhere
// (PromotionRecord, out of this sprint's scope) — it never removes one.
model Enrollment {
  id             String       @id @default(uuid(7))
  schoolId       String       @map("school_id")
  school         School       @relation(fields: [schoolId], references: [schoolId])
  studentId      String       @map("student_id")
  student        Student      @relation(fields: [studentId], references: [id])
  academicYearId String       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  sectionId      String       @map("section_id")
  section        Section      @relation(fields: [sectionId], references: [id])
  rollNumber     String       @map("roll_number")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  attendanceRecords AttendanceRecord[]

  @@unique([studentId, academicYearId])
  @@unique([sectionId, rollNumber])
  @@map("enrollments")
}

// --- Migration 005: Teacher Foundation --------------------------------------
// Sprint 4. Teacher, TeacherQualification, TeacherAssignment — see
// docs/database/MIGRATION_PLAN.md's Sprint 4 status note and
// docs/DECISIONS.md's Sprint 4 entry.
//
// `Teacher` has no `deletedAt`, matching `Student`'s precedent — DOMAIN_MODEL.md
// § 4.5 states the same "status is the only lifecycle signal" invariant
// (ACTIVE | ON_LEAVE | EXITED) that docs/database/DATABASE_REVIEW.md § 2
// explicitly established for Student; Teacher itself isn't one of that
// document's 11 reviewed entities, so this applies that already-established
// principle to new but analogous territory, not a fresh judgment call.
//
// `TeacherQualification.qualificationType` stays a plain String, NOT the
// lookup table docs/database/ENUM_STRATEGY.md § 5 recommends
// (`QualificationType: id, code, label, satisfiesRteMinimum`) — building
// that table now would mean inventing a new entity beyond this sprint's
// explicit "Do NOT invent entities" scope. Flagged as a real, documented,
// deliberately-deferred future improvement, not silently dropped.
//
// `TeacherAssignment` needs two separate constraints, not one — per
// docs/database/DATABASE_REVIEW.md § 7: `@@unique([academicYearId,
// sectionId, subjectId])` (Prisma-native, covers subject-assignment rows)
// does NOT enforce "exactly one class teacher per section per year", since
// Postgres treats multiple NULL `subjectId` values as distinct, not
// colliding. That rule needs its own hand-added partial unique index
// (`WHERE is_class_teacher = true`), same pattern as every other partial
// unique index in this schema.

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  EXITED

  @@map("teacher_status")
}

model Teacher {
  id          String        @id @default(cuid())
  schoolId    String        @map("school_id")
  school      School        @relation(fields: [schoolId], references: [schoolId])
  userId      String        @unique @map("user_id")
  user        User          @relation(fields: [userId], references: [id])
  firstName   String        @map("first_name")
  lastName    String        @map("last_name")
  phone       String
  gender      String?
  dateOfBirth DateTime?     @map("date_of_birth") @db.Timestamptz(3)
  photoUrl    String?       @map("photo_url")
  status      TeacherStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  qualifications TeacherQualification[]
  assignments    TeacherAssignment[]

  @@map("teachers")
}

model TeacherQualification {
  id                    String    @id @default(cuid())
  teacherId             String    @map("teacher_id")
  teacher               Teacher   @relation(fields: [teacherId], references: [id])
  qualificationType     String    @map("qualification_type")
  institution           String?
  yearCompleted         Int?      @map("year_completed")
  certificateDocumentId String?   @map("certificate_document_id")
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([teacherId])
  @@map("teacher_qualifications")
}

model TeacherAssignment {
  id             String       @id @default(cuid())
  academicYearId String       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  teacherId      String       @map("teacher_id")
  teacher        Teacher      @relation(fields: [teacherId], references: [id])
  sectionId      String       @map("section_id")
  section        Section      @relation(fields: [sectionId], references: [id])
  subjectId      String?      @map("subject_id")
  subject        Subject?     @relation(fields: [subjectId], references: [id])
  isClassTeacher Boolean      @default(false) @map("is_class_teacher")
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(3)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([academicYearId, sectionId, subjectId])
  @@index([teacherId, academicYearId])
  // The permission-check query ("is this teacher allowed to touch this
  // section"), run on every attendance/marks mutation once those exist —
  // docs/database/DATABASE_REVIEW.md § 7 names this "one of the
  // hottest-path lookups in the whole schema despite the table itself
  // being small."
  @@index([sectionId, academicYearId])
  @@map("teacher_assignments")
}

// --- Migration 006: Attendance ----------------------------------------------
// Sprint 5. AttendanceSession, AttendanceRecord — see
// docs/database/MIGRATION_PLAN.md's Sprint 5 status note and
// docs/DECISIONS.md's Sprint 5 entry.
//
// AttendanceRecord uses a time-ordered ID (UUIDv7), per
// docs/database/DATABASE_REVIEW.md § 9/§ 11 and MIGRATION_PLAN.md's own "006
// — Attendance" row ("apply the ULID/UUIDv7 primary key decision here, not
// retrofitted later") — the first genuinely high-volume table in the schema
// (600K-6.6M rows/school over 15 years). AttendanceSession stays cuid2 —
// trivial volume, one row per section per day.
//
// AttendanceSession carries its own schoolId directly, even though it's
// transitively scoped via Section -> SchoolClass -> School, matching
// Enrollment's own precedent (Migration 004) — docs/database/DATABASE_REVIEW.md
// § 9 names "(schoolId, date), for Admin's cross-section oversight view ('all
// sessions today, across every section')" as a needed composite index, which
// requires the direct column rather than a join through Section on every
// oversight-view query.
//
// markedByUserId/lastEditedByUserId are plain String columns, not Prisma
// relations to User — matching docs/domain/DATABASE_SCHEMA.md § 7's own
// illustrative shape and the same "who did this" pattern already used
// elsewhere in this schema without a formal relation (AuditLog.actorUserId,
// MarksRecord.enteredByUserId/lastEditedByUserId, TransferCertificate.issuedByUserId,
// DocumentRecord.uploadedByUserId) — avoids adding two more back-relation
// arrays to User for an audit-style reference.
//
// Neither table has a deletedAt or status field — per
// docs/database/SOFT_DELETE_STRATEGY.md § 1's third category ("historical
// fact/measurement — no delete mechanism at all"): a day's attendance,
// once taken, isn't deleted; corrections are audited edits
// (lastEditedByUserId/lastEditedAt on AttendanceSession), never row removal.
// AttendanceStatus is a native Postgres enum per docs/database/ENUM_STRATEGY.md
// § 2 — fixed, universal, not school-configurable
// (docs/domain/DOMAIN_MODEL.md § 7.2).

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE

  @@map("attendance_status")
}

model AttendanceSession {
  id                 String    @id @default(cuid())
  schoolId           String    @map("school_id")
  school             School    @relation(fields: [schoolId], references: [schoolId])
  sectionId          String    @map("section_id")
  section            Section   @relation(fields: [sectionId], references: [id])
  date               DateTime  @db.Date
  markedByUserId     String    @map("marked_by_user_id")
  lastEditedByUserId String?   @map("last_edited_by_user_id")
  lastEditedAt       DateTime? @map("last_edited_at") @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  records AttendanceRecord[]

  @@unique([sectionId, date])
  @@index([schoolId, date])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id           String            @id @default(uuid(7))
  sessionId    String            @map("session_id")
  session      AttendanceSession @relation(fields: [sessionId], references: [id])
  enrollmentId String            @map("enrollment_id")
  enrollment   Enrollment        @relation(fields: [enrollmentId], references: [id])
  status       AttendanceStatus
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  // "This student's attendance history for the year" — the existing unique
  // constraint below leads with sessionId, so this needs its own index, per
  // docs/database/DATABASE_REVIEW.md § 9.
  @@unique([sessionId, enrollmentId])
  @@index([enrollmentId])
  @@map("attendance_records")
}
