// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Sprint 0 — Data Foundation. Only Migration 000 (Audit Foundation) and
// Migration 001 (School Foundation) are implemented here — see
// docs/database/MIGRATION_PLAN.md § 2 for the full sequence and
// docs/database/PRISMA_IMPLEMENTATION_GUIDE.md for the conventions this
// file follows (naming, relation mode, datasource split).
//
// Once this schema exceeds ~15 models (PRISMA_IMPLEMENTATION_GUIDE.md § 1),
// split into prisma/schema/ by bounded context. Two models doesn't warrant
// that yet.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URLs are no longer configured here in Prisma 7 — `url`/`directUrl`
// on the datasource block were removed. Migrations read the connection from
// prisma.config.ts (DIRECT_URL, unpooled); the runtime client connects via a
// driver adapter (@prisma/adapter-pg, DATABASE_URL, pooled) constructed in
// src/lib/db.ts. See docs/database/PRISMA_IMPLEMENTATION_GUIDE.md § 2.
datasource db {
  provider = "postgresql"
}

// --- Migration 000: Audit Foundation ---------------------------------------
// Structurally standalone, no FKs out — see docs/database/MIGRATION_PLAN.md § 1
// for why AuditLog is built first, not last. Uses a time-ordered ID (UUIDv7)
// per docs/database/DATABASE_REVIEW.md § 11 — high insert volume, B-tree
// locality matters. Append-only: no updatedAt, no deletedAt (see
// docs/domain/DOMAIN_MODEL.md § 9.1). The REVOKE UPDATE/DELETE grant
// enforcement from docs/database/AUDIT_STRATEGY.md § 2 requires a real
// Postgres role name this environment doesn't have yet — see this sprint's
// "Manual Actions Required" note, not applied in this migration.
// Partitioning (AUDIT_STRATEGY.md § 3) deliberately deferred: created
// unpartitioned, with no composite primary key or unique constraint that
// would block converting it to a partitioned table later.

enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE

  @@map("audit_action")
}

model AuditLog {
  id          String      @id @default(uuid(7))
  schoolId    String      @map("school_id")
  entityType  String      @map("entity_type")
  entityId    String      @map("entity_id")
  actorUserId String      @map("actor_user_id")
  action      AuditAction
  beforeValue Json?       @map("before_value")
  afterValue  Json?       @map("after_value")
  timestamp   DateTime    @default(now()) @db.Timestamptz(3)

  @@index([entityType, entityId])
  @@index([actorUserId, timestamp])
  @@index([schoolId, timestamp])
  @@map("audit_logs")
}

// --- Migration 001: School Foundation ---------------------------------------
// The schoolId root every later migration hangs off — see
// docs/database/MIGRATION_PLAN.md § 2. School.schoolId is the primary key
// field name itself (not a generic `id`), since every other table's FK to
// School is named schoolId — see docs/domain/DATABASE_SCHEMA.md § 3.
// SchoolStatus's exact values aren't specified in docs/domain/DOMAIN_MODEL.md
// or docs/domain/DATABASE_SCHEMA.md (only AcademicYearStatus's ACTIVE|CLOSED
// is spelled out there) — ACTIVE/INACTIVE chosen here as the minimal
// two-state default consistent with this system's current single-tenant
// scope; INACTIVE has no application behavior yet.

enum SchoolStatus {
  ACTIVE
  INACTIVE

  @@map("school_status")
}

enum AcademicYearStatus {
  ACTIVE
  CLOSED

  @@map("academic_year_status")
}

model School {
  schoolId         String       @id @default(cuid()) @map("school_id")
  name             String
  shortName        String?      @map("short_name")
  affiliationBoard String?      @map("affiliation_board")
  udiseCode        String?      @unique @map("udise_code")
  status           SchoolStatus @default(ACTIVE)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  academicYears AcademicYear[]
  users         User[]

  @@map("schools")
}

model AcademicYear {
  id              String             @id @default(cuid())
  schoolId        String             @map("school_id")
  school          School             @relation(fields: [schoolId], references: [schoolId])
  label           String
  startDate       DateTime           @map("start_date") @db.Timestamptz(3)
  endDate         DateTime           @map("end_date") @db.Timestamptz(3)
  isCurrent       Boolean            @default(false) @map("is_current")
  // Exactly one true per school — schema-enforced via a partial unique index
  // (WHERE is_current = true), hand-added in this migration's SQL, not
  // expressible in schema.prisma syntax. See
  // docs/database/CONSTRAINT_STRATEGY.md § 3.
  status          AcademicYearStatus @default(ACTIVE)
  promotionPolicy Json               @map("promotion_policy")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([schoolId, label])
  @@index([schoolId, isCurrent])
  @@map("academic_years")
}

// --- Migration 002: Identity Foundation -------------------------------------
// Sprint 1. Physically the second migration built after 001 — numbered 002
// since Migration 002 (Academic Structure — Class/Section/Subject) in
// docs/database/MIGRATION_PLAN.md § 2 hasn't been built yet. Valid ordering:
// that table's own "Depends on" column lists Identity as depending only on
// 001, not on Academic Structure. See MIGRATION_PLAN.md's Sprint 1 status
// note for the full reconciliation — this is a build-order note, not a
// redesign of the conceptual plan.
//
// Scope is narrower than MIGRATION_PLAN.md's original "Migration 003 —
// Identity" slot: `Teacher`/`TeacherQualification` are explicitly out of
// this sprint ("no business modules") and remain for a later migration.
// `Role`, `Account`, `Session`, `VerificationToken` are new — the Auth.js
// adapter's own required shape, which the conceptual domain model never
// modeled (auth infrastructure, not a business entity). See
// docs/DECISIONS.md's Sprint 1 entry.
//
// `Account`/`Session` follow Auth.js v5's (@auth/prisma-adapter) canonical
// Prisma schema exactly — including keeping `Account`'s OAuth-response
// fields (access_token, refresh_token, expires_at, token_type, id_token,
// session_state) as literal snake_case field names, not this project's
// usual camelCase-field-with-@map convention. The adapter constructs its
// Prisma calls using these exact literal keys; renaming them would silently
// break OAuth token storage. This is a deliberate, narrow exception to
// DEVELOPMENT_CONVENTIONS.md § 1, not an oversight.

enum AccessLevel {
  ADMIN
  TEACHER

  @@map("access_level")
}

// A lookup/reference table, not a many-to-many join — every User has
// exactly one Role in V1 (D-001: Guest/Admin/Teacher only). `name` is the
// human-facing job title ("Administrator", "Principal", "Teacher");
// `accessLevel` is the actual permission tier PERMISSION_MATRIX.md's rules
// check against. Two different `name` rows can share one `accessLevel` —
// PROJECT_CONTEXT.md § 4 already describes "Admin" as covering "Principal /
// Management / School Office" job titles, so seeding "Administrator" and
// "Principal" as two Role rows, both ADMIN-tier, matches that framing
// exactly rather than introducing a fourth real permission tier.
model Role {
  id          String      @id @default(cuid())
  name        String      @unique
  accessLevel AccessLevel @map("access_level")
  description String?
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  users User[]

  @@map("roles")
}

// Auth.js adapter User, extended with this app's own fields (schoolId,
// roleId, passwordHash, deactivatedAt) — one User table serves both
// purposes, per ARCHITECTURE.md § 9's Auth.js provider question ("wire in
// whichever provider is chosen") remaining unresolved by design: this
// schema supports either a Credentials or an email/magic-link provider
// without redesign. `roleId` is required, not nullable — this app has no
// public self-registration (D-001; Admin provisions every account), so
// every real User row is created through an Admin-driven flow that assigns
// a role at creation time, never through the adapter's own auto-create path.
model User {
  id            String    @id @default(cuid())
  schoolId      String    @map("school_id")
  school        School    @relation(fields: [schoolId], references: [schoolId])
  roleId        String    @map("role_id")
  role          Role      @relation(fields: [roleId], references: [id])
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified") @db.Timestamptz(3)
  image         String?
  passwordHash  String?   @map("password_hash")
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  accounts Account[]
  sessions Session[]

  @@index([schoolId])
  @@index([roleId])
  @@map("users")
}

// Auth.js adapter Account — OAuth provider link. Field names/shapes are the
// adapter's own contract, see the migration-header comment above.
model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// Auth.js adapter Session — database session strategy.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Auth.js adapter VerificationToken — email/magic-link + email-verification
// flows. No single `id` field, per the adapter's own canonical schema — the
// composite (identifier, token) unique constraint is this model's key.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz(3)

  @@unique([identifier, token])
  @@map("verification_tokens")
}
