# Copy this file to .env.local and fill in real values. Never commit .env or .env.local.
# See docs/DEVELOPMENT_CONVENTIONS.md § Environment Variables for naming rules.

# --- Database (PostgreSQL via Prisma) ---
# DATABASE_URL: pooled connection, used by the runtime client (src/lib/db.ts).
# DIRECT_URL: unpooled connection, used by Prisma Migrate (prisma.config.ts).
# If your Postgres host has no pooler, both can point at the same database.
DATABASE_URL="postgresql://user:password@localhost:5432/pant_public_school?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/pant_public_school?schema=public"

# --- Auth.js (next-auth v5) ---
# Generate with: pnpm dlx auth secret
AUTH_SECRET="replace-with-a-generated-secret"
AUTH_URL="http://localhost:3000"

# --- Cloudinary (media hosting) ---
CLOUDINARY_CLOUD_NAME="replace-with-cloud-name"
CLOUDINARY_API_KEY="replace-with-api-key"
CLOUDINARY_API_SECRET="replace-with-api-secret"

# --- App ---
# Client-safe base URL, used for absolute links/metadata where needed.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
